# ============================================================
# Digi_TransX — Environment Configuration
# Copy this file to `.env` in the project root and fill it in.
# NEVER commit the real .env file.
# ============================================================

# ---- Supabase (required) -----------------------------------
# Project URL and API keys: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://fysupkvuvhvtowbfgoev.supabase.co
SUPABASE_ANON_KEY=sb_publishable_gnfaqXGjAHZIWKuJslsCwA_VXtLluPQ
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Postgres connection string: Dashboard -> Project Settings -> Database
# Use the "Session pooler" URI on IPv4 networks.
SUPABASE_DB_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Private storage bucket for all uploaded files (created by supabase/schema.sql)
SUPABASE_STORAGE_BUCKET=shipment-documents

# Max DB connections kept in the backend pool
SUPABASE_DB_POOL_MAX=10

# Timezone used for timestamps shown in the app
APP_TIMEZONE=Asia/Karachi

# ---- Flask -------------------------------------------------
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true
# Set to "production" on the live server (enables secure cookies)
# FLASK_ENV=production

# ---- Email (OTP / password reset) --------------------------
DIGITRANSX_SMTP_HOST=smtp.gmail.com
DIGITRANSX_SMTP_PORT=587
DIGITRANSX_SMTP_USER=your-email@gmail.com
DIGITRANSX_SMTP_PASSWORD=your-gmail-app-password
DIGITRANSX_SMTP_FROM=your-email@gmail.com
