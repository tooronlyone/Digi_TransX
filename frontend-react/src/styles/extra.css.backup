/* ============================================
   Shared Placeholder Pages
   ============================================ */

.t-page-card {
  max-width: 880px;
  margin: 24px auto 0;
  padding: 32px;
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 253, 0.96));
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-elevated);
}

.t-page-eyebrow {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.1);
  color: var(--accent-primary);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.t-page-title {
  font-size: 34px;
  line-height: 1.05;
  letter-spacing: -0.04em;
  color: var(--accent-secondary);
  margin-bottom: 12px;
}

.t-page-description {
  color: var(--text-secondary);
  font-size: 15px;
  line-height: 1.7;
  max-width: 60ch;
}

.t-page-meta {
  margin-top: 24px;
  padding: 16px 18px;
  border-radius: 16px;
  background: var(--hover-bg);
  border: 1px solid var(--border-subtle);
}

.t-page-meta span {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.t-page-meta code {
  display: block;
  white-space: pre-wrap;
  word-break: break-word;
  color: var(--text-primary);
  font-size: 13px;
}

/* ============================================
   Page: Edit Truck Redirect
   ============================================ */

.page-edit-truck-redirect .edit-truck-container {
  min-height: calc(100vh - 70px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px 20px;
}

.page-edit-truck-redirect .loading-state {
  min-width: 280px;
  text-align: center;
  padding: 32px 28px;
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 253, 0.96));
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-elevated);
}

.page-edit-truck-redirect .loading-state i {
  font-size: 42px;
  color: var(--accent-primary);
  display: block;
  margin-bottom: 14px;
}

.page-edit-truck-redirect .loading-state p {
  color: var(--text-secondary);
  font-size: 14px;
}

/* ============================================
   Page: Truck Configuration
   ============================================ */

.page-truck-configuration .config-shell {
  max-width: 1080px;
  margin: 0 auto;
}

.page-truck-configuration .back-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 18px;
  color: var(--accent-primary);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
}

.page-truck-configuration .page-header {
  margin-bottom: 32px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-subtle);
}

.page-truck-configuration .page-header h1 {
  font-size: 34px;
  line-height: 1.04;
  letter-spacing: -0.04em;
  color: var(--accent-secondary);
  margin-bottom: 10px;
}

.page-truck-configuration .page-header p {
  color: var(--text-secondary);
  font-size: 15px;
  line-height: 1.7;
}

.page-truck-configuration .loading-state,
.truck-state-card {
  text-align: center;
  padding: 42px 28px;
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 253, 0.96));
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-elevated);
}

.page-truck-configuration .loading-state i {
  font-size: 36px;
  color: var(--accent-primary);
  margin-bottom: 12px;
}

.page-truck-configuration .status-panel {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-bottom: 24px;
}

.page-truck-configuration .status-item,
.page-truck-configuration .missing-fields {
  padding: 20px;
  border-radius: 20px;
  background: var(--surface-white);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-subtle);
}

.page-truck-configuration .status-label,
.page-truck-configuration .missing-fields-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 10px;
}

.page-truck-configuration .config-completeness {
  font-size: 28px;
  font-weight: 800;
  color: var(--accent-secondary);
}

.page-truck-configuration .missing-fields-copy {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.6;
}

.page-truck-configuration .status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
}

.page-truck-configuration .status-active {
  background: rgba(16, 185, 129, 0.12);
  color: var(--success);
}

.page-truck-configuration .status-draft {
  background: rgba(245, 158, 11, 0.12);
  color: var(--warning);
}

.page-truck-configuration .config-form {
  display: grid;
  gap: 22px;
}

.page-truck-configuration .config-card {
  padding: 26px 28px;
  border-radius: 24px;
  background: var(--surface-white);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-subtle);
}

.page-truck-configuration .config-card h2 {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent-secondary);
  margin-bottom: 8px;
}

.page-truck-configuration .section-note {
  color: var(--text-muted);
  font-size: 13px;
  margin-bottom: 18px;
}

.page-truck-configuration .field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.page-truck-configuration .field-grid > label,
.page-truck-configuration .checkbox-field {
  display: flex;
  flex-direction: column;
  gap: 8px;
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 600;
}

.page-truck-configuration .field-grid > label.full-width,
.page-truck-configuration .upload-field.full-width {
  grid-column: 1 / -1;
}

.page-truck-configuration input,
.page-truck-configuration select,
.page-truck-configuration textarea {
  width: 100%;
  padding: 12px 14px;
  border-radius: 12px;
  border: 1px solid var(--border-subtle);
  background: var(--surface-white);
  color: var(--text-primary);
  font-size: 14px;
}

.page-truck-configuration input:focus,
.page-truck-configuration select:focus,
.page-truck-configuration textarea:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
}

.page-truck-configuration small {
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 400;
}

.page-truck-configuration .province-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.page-truck-configuration .province-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid var(--border-subtle);
  background: var(--hover-bg);
  cursor: pointer;
  transition: all 0.2s ease;
}

.page-truck-configuration .province-chip input {
  width: 16px;
  height: 16px;
  accent-color: var(--accent-primary);
}

.page-truck-configuration .province-chip.selected {
  background: rgba(37, 99, 235, 0.08);
  border-color: rgba(37, 99, 235, 0.3);
  color: var(--accent-primary);
}

.page-truck-configuration .checkbox-field {
  flex-direction: row;
  align-items: center;
  padding: 16px;
  border-radius: 16px;
  border: 1px solid var(--border-subtle);
  background: var(--hover-bg);
}

.page-truck-configuration .checkbox-field input {
  width: 18px;
  height: 18px;
  accent-color: var(--accent-primary);
}

.page-truck-configuration .upload-field input[type='file'] {
  padding: 11px 12px;
}

.page-truck-configuration .form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}

.page-truck-configuration .btn,
.page-truck-configuration .btn.secondary,
.page-truck-configuration .btn.primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  padding: 0 20px;
  border-radius: 14px;
  border: 1px solid transparent;
  cursor: pointer;
  font-size: 14px;
  font-weight: 700;
  transition: all 0.2s ease;
}

.page-truck-configuration .btn.primary {
  background: var(--gradient-primary);
  color: white;
  box-shadow: var(--shadow-medium);
}

.page-truck-configuration .btn.secondary {
  background: var(--hover-bg);
  border-color: var(--border-subtle);
  color: var(--text-secondary);
}

.page-truck-configuration .btn:hover {
  transform: translateY(-2px);
}

.page-truck-configuration .toast-container {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 1200;
}

.page-truck-configuration .toast {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 18px;
  border-radius: 16px;
  color: white;
  box-shadow: var(--shadow-elevated);
}

.page-truck-configuration .toast.success {
  background: linear-gradient(135deg, #10b981, #34d399);
}

.page-truck-configuration .toast.error {
  background: linear-gradient(135deg, #ef4444, #f87171);
}

/* ============================================
   Shared Fleet Detail Pages
   ============================================ */

.page-truck-details,
.page-track-truck,
.page-service-history {
  --fleet-surface: rgba(255, 255, 255, 0.96);
  --fleet-surface-alt: #f3f7fb;
  --fleet-border: rgba(148, 163, 184, 0.22);
  --fleet-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  --fleet-hero: linear-gradient(135deg, #09192f 0%, #14355f 38%, #1a57a5 72%, #2b88f0 100%);
}

.page-truck-details .topbar,
.page-track-truck .page,
.page-service-history .page {
  max-width: 1200px;
  margin: 0 auto;
}

.page-truck-details .topbar {
  margin-bottom: 24px;
  padding: 28px;
  border-radius: 28px;
  background: var(--fleet-surface);
  border: 1px solid var(--fleet-border);
  box-shadow: var(--fleet-shadow);
}

.page-truck-details .topbar h1 {
  font-size: 38px;
  line-height: 1.02;
  letter-spacing: -0.04em;
  color: var(--accent-secondary);
}

.page-truck-details .topbar p {
  margin-top: 8px;
  color: var(--text-secondary);
  max-width: 60ch;
  line-height: 1.65;
}

.page-track-truck .page,
.page-service-history .page {
  display: grid;
  gap: 24px;
}

.page-truck-details .hero-section,
.page-track-truck .hero,
.page-service-history .hero {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
  padding: 28px;
  border-radius: 28px;
  background: var(--fleet-hero);
  color: #f8fbff;
  box-shadow: 0 24px 48px rgba(15, 23, 42, 0.16);
}

.page-truck-details .hero-copy h2,
.page-track-truck .hero h2,
.page-service-history .hero h2 {
  font-size: clamp(30px, 4vw, 48px);
  line-height: 0.98;
  letter-spacing: -0.05em;
  margin-bottom: 12px;
}

.page-truck-details .hero-copy p,
.page-track-truck .hero p,
.page-service-history .hero p {
  color: rgba(248, 251, 255, 0.88);
  line-height: 1.7;
  max-width: 60ch;
}

.page-truck-details .hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 8px 14px;
  margin-bottom: 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.12);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.page-truck-details .hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.page-truck-details .hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: rgba(248, 251, 255, 0.96);
  font-size: 13px;
  font-weight: 600;
}

.page-truck-details .hero-actions,
.page-track-truck .hero-actions,
.page-service-history .hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: flex-start;
}

.page-truck-details .btn,
.page-truck-details .btn-secondary,
.page-track-truck .btn,
.page-track-truck .btn-secondary,
.page-service-history .btn,
.page-service-history .btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  padding: 0 18px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.page-truck-details .btn,
.page-track-truck .btn,
.page-service-history .btn {
  background: linear-gradient(135deg, #ffffff 0%, #eef5ff 100%);
  color: var(--accent-primary-dark);
}

.page-truck-details .btn-secondary,
.page-track-truck .btn-secondary,
.page-service-history .btn-secondary {
  background: rgba(255, 255, 255, 0.14);
  color: white;
  border-color: rgba(255, 255, 255, 0.12);
}

.page-truck-details .btn:hover,
.page-truck-details .btn-secondary:hover,
.page-track-truck .btn:hover,
.page-track-truck .btn-secondary:hover,
.page-service-history .btn:hover,
.page-service-history .btn-secondary:hover {
  transform: translateY(-2px);
}

.page-truck-details .cards-grid,
.page-track-truck .cards,
.page-service-history .cards {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
}

.page-truck-details .metric-card,
.page-track-truck .card,
.page-service-history .card,
.page-truck-details .feature-panel,
.page-track-truck .section,
.page-service-history .section {
  background: var(--fleet-surface);
  border: 1px solid var(--fleet-border);
  border-radius: 24px;
  box-shadow: var(--fleet-shadow);
}

.page-truck-details .metric-card,
.page-track-truck .card,
.page-service-history .card {
  padding: 22px;
}

.page-truck-details .metric-icon {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  margin-bottom: 16px;
  border-radius: 16px;
  background: linear-gradient(135deg, #0f3f95 0%, #2b88f0 100%);
  color: white;
  box-shadow: 0 12px 24px rgba(29, 108, 240, 0.16);
}

.page-truck-details .metric-label,
.page-track-truck .metric-label,
.page-service-history .metric-label {
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 10px;
}

.page-truck-details .metric-value,
.page-track-truck .metric-value,
.page-service-history .metric-value {
  font-size: clamp(24px, 2.2vw, 34px);
  line-height: 1.08;
  letter-spacing: -0.04em;
  color: var(--accent-secondary);
}

.page-truck-details .metric-note,
.page-track-truck .metric-note,
.page-service-history .metric-note {
  margin-top: 12px;
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.6;
}

.page-truck-details .section-grid,
.page-track-truck .section-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 18px;
}

.page-truck-details .feature-panel,
.page-track-truck .section,
.page-service-history .section {
  padding: 24px;
}

.page-truck-details .section-head,
.page-service-history .toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}

.page-truck-details .section-head h3,
.page-track-truck .section h3,
.page-service-history .section h3 {
  font-size: 18px;
  font-weight: 700;
  color: var(--accent-secondary);
}

.page-truck-details .section-head p {
  margin-top: 6px;
  font-size: 13px;
  color: var(--text-muted);
}

.page-truck-details .meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.page-truck-details .meta-item {
  padding: 16px;
  border-radius: 18px;
  background: var(--fleet-surface-alt);
  border: 1px solid rgba(148, 163, 184, 0.18);
}

.page-truck-details .meta-label {
  display: block;
  margin-bottom: 8px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.page-truck-details .meta-value {
  color: var(--text-primary);
  font-size: 14px;
  font-weight: 600;
  word-break: break-word;
}

.page-truck-details .list,
.page-track-truck .timeline {
  display: grid;
  gap: 12px;
}

.page-truck-details .list-item,
.page-track-truck .timeline-item {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding: 16px;
  border-radius: 18px;
  background: var(--fleet-surface-alt);
  border: 1px solid rgba(148, 163, 184, 0.16);
}

.page-truck-details .list-icon,
.page-track-truck .timeline-dot {
  width: 20px;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  padding-top: 2px;
}

.page-track-truck .timeline-dot {
  width: 8px;
  height: 8px;
  margin-top: 6px;
  padding-top: 0;
  border-radius: 999px;
  background: var(--accent-primary);
}

.page-truck-details .list-title,
.page-track-truck .timeline-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--accent-secondary);
  margin-bottom: 4px;
}

.page-truck-details .list-desc,
.page-track-truck .timeline-copy,
.page-track-truck .empty-copy {
  color: var(--text-secondary);
  font-size: 13px;
  line-height: 1.6;
}

.page-truck-details .table-wrap,
.page-track-truck .table-wrap,
.page-service-history .table-wrap {
  overflow-x: auto;
}

.page-track-truck .progress-shell {
  height: 10px;
  margin-top: 12px;
  overflow: hidden;
  border-radius: 999px;
  background: #dbe5f3;
}

.page-track-truck .progress-fill {
  height: 100%;
  border-radius: 999px;
}

.page-track-truck .route-stack {
  display: grid;
  gap: 14px;
}

.page-track-truck .route-node {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.page-track-truck .route-dot {
  width: 12px;
  height: 12px;
  margin-top: 5px;
  border-radius: 50%;
  flex-shrink: 0;
}

.page-track-truck .route-dot-start { background: #22c55e; }
.page-track-truck .route-dot-end { background: #ef4444; }

.page-track-truck .route-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.page-track-truck .route-value {
  font-size: 15px;
  font-weight: 600;
  color: var(--accent-secondary);
}

.page-track-truck .route-divider {
  margin-left: 5px;
  padding-left: 18px;
  border-left: 2px dashed var(--border-light);
  color: var(--text-muted);
  font-size: 13px;
}

.page-track-truck .route-meta {
  padding: 12px 14px;
  border-radius: 14px;
  background: var(--fleet-surface-alt);
  color: var(--text-secondary);
  font-size: 13px;
  line-height: 1.7;
}

.page-track-truck .truck-empty-section {
  text-align: center;
}

.page-track-truck .truck-empty-icon {
  font-size: 46px;
  color: #94a3b8;
  margin-bottom: 16px;
}

.truck-toast {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 1200;
  padding: 12px 18px;
  border-radius: 14px;
  background: linear-gradient(135deg, #10b981, #34d399);
  color: white;
  box-shadow: var(--shadow-elevated);
}

.page-service-history .summary-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.page-service-history .pill {
  display: inline-flex;
  align-items: center;
  padding: 9px 14px;
  border-radius: 999px;
  background: var(--fleet-surface-alt);
  border: 1px solid rgba(148, 163, 184, 0.16);
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 600;
}

/* ============================================
   Page: Leaderboard
   ============================================ */

.page-leaderboard .leaderboard-placeholder {
  max-width: 900px;
  margin: 24px auto 0;
  padding: 42px 32px;
  text-align: center;
  border-radius: 28px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 253, 0.96));
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-elevated);
}

.page-leaderboard .leaderboard-placeholder-icon {
  width: 82px;
  height: 82px;
  margin: 0 auto 18px;
  display: grid;
  place-items: center;
  border-radius: 24px;
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: white;
  font-size: 34px;
  box-shadow: 0 18px 34px rgba(245, 158, 11, 0.24);
}

.page-leaderboard .leaderboard-placeholder h2 {
  font-size: 28px;
  line-height: 1.06;
  letter-spacing: -0.03em;
  color: var(--accent-secondary);
  margin-bottom: 10px;
}

.page-leaderboard .leaderboard-placeholder p {
  max-width: 56ch;
  margin: 0 auto;
  color: var(--text-secondary);
  font-size: 15px;
  line-height: 1.7;
}

.page-leaderboard .leaderboard-placeholder-actions {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 22px;
}

/* ============================================
   Page: Maintenance
   ============================================ */

.page-maintenance .top-bar {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--border-subtle);
}

.page-maintenance .page-shortcuts {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 32px;
  padding: 8px 0;
}

.page-maintenance .page-shortcut {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px;
  background: var(--surface-white);
  border: 1px solid var(--border-subtle);
  border-radius: 40px;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  transition: all 0.2s;
}

.page-maintenance .page-shortcut:hover {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
  transform: translateY(-2px);
}

.page-maintenance .page-shortcut.active {
  background: var(--gradient-primary);
  border-color: transparent;
  color: white;
  box-shadow: var(--shadow-medium);
}

.page-maintenance .card {
  background: var(--surface-white);
  border-radius: 20px;
  padding: 28px;
  margin-bottom: 28px;
  border: 1px solid var(--border-subtle);
  transition: all 0.3s;
  box-shadow: var(--shadow-subtle);
}

.page-maintenance .card:hover {
  box-shadow: var(--shadow-elevated);
}

.page-maintenance .card h2 {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent-secondary);
  margin-bottom: 24px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border-subtle);
  position: relative;
}

.page-maintenance .card h2::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -1px;
  width: 50px;
  height: 3px;
  background: var(--gradient-primary);
  border-radius: 2px;
}

.page-maintenance .wide-card {
  grid-column: 1 / -1;
}

.page-maintenance .form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.page-maintenance .form-grid input,
.page-maintenance .form-grid select,
.page-maintenance .form-grid button {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
  font-size: 14px;
  transition: all 0.2s;
  background: var(--surface-white);
  color: var(--text-primary);
}

.page-maintenance .form-grid input:focus,
.page-maintenance .form-grid select:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.page-maintenance .form-grid .full-width {
  grid-column: 1 / -1;
}

.page-maintenance .form-grid button {
  background: var(--gradient-primary);
  color: white;
  border: none;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.page-maintenance .form-grid button:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-medium);
}

.page-maintenance .expense-summary {
  background: var(--hover-bg);
  border-radius: 16px;
  padding: 20px;
}

.page-maintenance .expense-summary h3 {
  font-size: 16px;
  font-weight: 600;
  color: var(--accent-secondary);
  margin-bottom: 16px;
}

.page-maintenance .expense-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 24px;
}

.page-maintenance .expense-filters select,
.page-maintenance .expense-filters input,
.page-maintenance .filter-controls select,
.page-maintenance .filter-controls input {
  padding: 10px 14px;
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  font-size: 13px;
  background: var(--surface-white);
  color: var(--text-primary);
}

.page-maintenance .date-range-selector {
  display: flex;
  align-items: center;
  gap: 8px;
}

.page-maintenance .date-range-selector span {
  color: var(--text-muted);
}

.page-maintenance .expense-results {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.page-maintenance .expense-card {
  background: var(--surface-white);
  border-radius: 12px;
  padding: 16px;
  text-align: center;
  border: 1px solid var(--border-subtle);
}

.page-maintenance .expense-card h4 {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.page-maintenance .filter-controls {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 24px;
  align-items: center;
}

.page-maintenance .search-bar {
  min-width: 200px;
  position: relative;
}

.page-maintenance .search-bar input {
  width: 100%;
  padding: 10px 14px 10px 40px;
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  font-size: 13px;
  background: var(--surface-white);
  color: var(--text-primary);
}

.page-maintenance .search-bar input:focus {
  outline: none;
  border-color: var(--accent-primary);
}

.page-maintenance .search-bar i {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
}

.page-maintenance .filter-btn {
  background: var(--gradient-primary);
  color: white;
  border: none;
  padding: 10px 18px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.page-maintenance .filter-btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-medium);
}

.page-maintenance .reset-btn {
  background: var(--hover-bg);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
}

.page-maintenance .reset-btn:hover {
  background: var(--surface-white);
  border-color: var(--accent-primary);
  color: var(--accent-primary);
}

.page-maintenance .print-btn {
  background: linear-gradient(135deg, #10b981, #34d399);
}

.page-maintenance .table-responsive {
  overflow-x: auto;
  border-radius: 12px;
  border: 1px solid var(--border-subtle);
}

.page-maintenance table {
  width: 100%;
  border-collapse: collapse;
}

.page-maintenance th {
  text-align: left;
  padding: 12px 14px;
  background: var(--hover-bg);
  color: var(--accent-secondary);
  font-weight: 700;
  font-size: 12px;
  border-bottom: 1px solid var(--border-subtle);
  white-space: nowrap;
}

.page-maintenance td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border-subtle);
  color: var(--text-secondary);
  font-size: 13px;
}

.page-maintenance tr:hover td {
  background: var(--hover-bg);
}

/* ============================================
   Responsive
   ============================================ */

@media (max-width: 1200px) {
  .page-truck-configuration .status-panel,
  .page-truck-details .cards-grid,
  .page-track-truck .cards,
  .page-service-history .cards,
  .page-maintenance .expense-results {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 992px) {
  .page-truck-configuration .status-panel,
  .page-truck-configuration .field-grid,
  .page-truck-details .meta-grid,
  .page-truck-details .section-grid,
  .page-track-truck .section-grid,
  .page-maintenance .form-grid,
  .page-maintenance .expense-results {
    grid-template-columns: 1fr;
  }

  .page-maintenance .filter-controls {
    flex-direction: column;
    align-items: stretch;
  }

  .page-maintenance .search-bar {
    width: 100%;
  }
}

@media (max-width: 768px) {
  .t-page-card,
  .page-leaderboard .leaderboard-placeholder,
  .page-truck-details .topbar,
  .page-truck-details .hero-section,
  .page-track-truck .hero,
  .page-service-history .hero,
  .page-truck-details .feature-panel,
  .page-track-truck .section,
  .page-service-history .section,
  .page-truck-configuration .config-card,
  .page-truck-configuration .loading-state,
  .truck-state-card {
    padding: 22px;
  }

  .page-truck-configuration .status-panel,
  .page-truck-details .cards-grid,
  .page-track-truck .cards,
  .page-service-history .cards {
    grid-template-columns: 1fr;
  }

  .page-track-truck .hero-actions,
  .page-service-history .hero-actions,
  .page-truck-details .hero-actions,
  .page-truck-configuration .form-actions,
  .page-leaderboard .leaderboard-placeholder-actions {
    flex-direction: column;
  }

  .page-maintenance .page-shortcuts {
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 8px;
  }

  .page-maintenance .card {
    padding: 20px;
  }

  .page-maintenance .expense-filters {
    flex-direction: column;
  }

  .page-maintenance .date-range-selector {
    flex-wrap: wrap;
  }

  .page-track-truck .btn,
  .page-track-truck .btn-secondary,
  .page-service-history .btn,
  .page-service-history .btn-secondary,
  .page-truck-details .btn,
  .page-truck-details .btn-secondary,
  .page-truck-configuration .btn {
    width: 100%;
  }

  .page-truck-configuration .province-grid {
    grid-template-columns: 1fr;
  }

  .page-maintenance th,
  .page-maintenance td {
    padding: 8px 10px;
    font-size: 12px;
  }
}
