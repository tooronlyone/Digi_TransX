  color: var(--warning);
}

.transporter-page .progress-bar,
.transporter-page .score-bg,
.transporter-page .trend-bar-track {
  height: 8px;
  overflow: hidden;
  border-radius: 999px;
  background: var(--hover-bg);
}

.transporter-page .progress-fill,
.transporter-page .score-progress,
.transporter-page .trend-bar-fill,
.transporter-page .distribution-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-primary);
}

.transporter-page .table-responsive,
.transporter-page .history-table-container,
.transporter-page .recent-jobs-table,
.transporter-page .table-view {
  overflow-x: auto;
  background: var(--surface-white);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  box-shadow: var(--shadow-subtle);
}

.transporter-page .modal,
.transporter-page .chat-modal {
  position: fixed;
  inset: 0;
  z-index: 1300;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.48);
  padding: 24px;
}

.transporter-page .modal-content,
.transporter-page .chat-modal-content {
  width: min(680px, 100%);
  max-height: calc(100vh - 48px);
  overflow: auto;
  background: var(--surface-white);
  border-radius: 22px;
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-elevated);
  padding: 24px;
}

.transporter-page .modal-header,
.transporter-page .chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding-bottom: 16px;
  margin-bottom: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.transporter-page .privacy-layout,
.transporter-page .terms-layout {
  grid-template-columns: minmax(0, 1fr) 280px;
  align-items: start;
}

.transporter-page .privacy-main,
.transporter-page .terms-main {
  display: grid;
  gap: 20px;
}

.transporter-page .privacy-sidebar,
.transporter-page .terms-sidebar {
