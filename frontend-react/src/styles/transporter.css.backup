  gap: 16px;
}

.transporter-page .privacy-nav-list,
.transporter-page .terms-nav-list,
.transporter-page .privacy-points,
.transporter-page .terms-points,
.transporter-page .history-list,
.transporter-page .snapshot-list,
.transporter-page .distribution-list,
.transporter-page .nearby-list {
