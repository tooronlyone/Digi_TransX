}

.transporter-page .timeline,
.transporter-page .timeline-view {
  display: grid;
  gap: 16px;
}

.transporter-page .timeline-item,
.transporter-page .history-item,
.transporter-page .snapshot-item,
.transporter-page .distribution-row,
.transporter-page .summary-row,
.transporter-page .detail-row,
.transporter-page .breakdown-item,
.transporter-page .trend-bar {
