  border-bottom: 1px solid var(--border-subtle);
}

.transporter-page .timeline-dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: var(--accent-primary);
  flex-shrink: 0;
}

.transporter-page .timeline-content,
.transporter-page .list-content {
  flex: 1;
}

.transporter-page .timeline-title,
.transporter-page .detail-title,
.transporter-page .insight-title,
.transporter-page .projection-period,
.transporter-page .nearby-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--accent-secondary);
}

.transporter-page .timeline-desc,
.transporter-page .review-text,
.transporter-page .message-time,
.transporter-page .detail-label {
  color: var(--text-muted);
  font-size: 13px;
  line-height: 1.6;
}

.transporter-page .settings-container {
  display: grid;
  grid-template-columns: 260px minmax(0, 1fr);
  gap: 24px;
  align-items: start;
}

.transporter-page .settings-sidebar,
.transporter-page .settings-content {
  background: var(--surface-white);
  border: 1px solid var(--border-subtle);
  border-radius: 20px;
  padding: 20px;
  box-shadow: var(--shadow-subtle);
}

.transporter-page .settings-menu {
  display: grid;
  gap: 8px;
}

.transporter-page .settings-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 12px;
  border-radius: 10px;
  color: var(--text-secondary);
  cursor: pointer;
}

.transporter-page .settings-menu-item.active,
.transporter-page .settings-menu-item:hover {
  background: rgba(37, 99, 235, 0.1);
  color: var(--accent-primary);
}

.transporter-page .toggle-switch {
  position: relative;
  display: inline-flex;
  width: 46px;
  height: 26px;
  border-radius: 999px;
  background: var(--border-light);
  cursor: pointer;
}

.transporter-page .toggle-slider {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: white;
  transition: transform 0.2s;
}

.transporter-page input:checked + .toggle-slider {
  transform: translateX(20px);
}

.transporter-page .profile-container {
  grid-template-columns: 320px minmax(0, 1fr);
}

.transporter-page .profile-card {
  text-align: center;
}

.transporter-page .profile-img-placeholder,
.transporter-page .team-avatar,
.transporter-page .reviewer-avatar {
  width: 92px;
  height: 92px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-primary);
  color: white;
  font-size: 32px;
  font-weight: 800;
  margin-bottom: 18px;
}

.transporter-page .profile-name {
  font-size: 24px;
  font-weight: 800;
  color: var(--accent-secondary);
}

.transporter-page .profile-role {
  color: var(--text-muted);
  margin-top: 4px;
}

.transporter-page .error-message {
  color: var(--error);
  font-size: 13px;
  margin-top: 6px;
}

@media (max-width: 992px) {
  .transporter-page .privacy-layout,
  .transporter-page .terms-layout,
  .transporter-page .settings-container,
  .transporter-page .profile-container {
    grid-template-columns: 1fr;
  }

  .transporter-page .privacy-sidebar,
  .transporter-page .terms-sidebar {
    position: static;
  }
}

@media (max-width: 768px) {
  .transporter-page .page-shortcuts {
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 10px;
  }

  .transporter-page .summary-cards,
  .transporter-page .stats-cards,
  .transporter-page .fleet-stats,
  .transporter-page .fuel-stats,
  .transporter-page .settings-cards,
  .transporter-page .rating-summary-grid,
  .transporter-page .rating-overview-grid,
  .transporter-page .rating-analytics-grid,
  .transporter-page .details-grid,
  .transporter-page .services-grid,
  .transporter-page .team-grid,
  .transporter-page .jobs-grid,
  .transporter-page .trends-container,
  .transporter-page .utilization-cards,
  .transporter-page .projections-grid,
  .transporter-page .insights-grid {
    grid-template-columns: 1fr;
  }

  .transporter-page .section-header,
  .transporter-page .jobs-header,
  .transporter-page .chart-header,
  .transporter-page .summary-header,
  .transporter-page .table-header,
  .transporter-page .timeline-item,
  .transporter-page .summary-row,
  .transporter-page .detail-row {
    align-items: flex-start;
    flex-direction: column;
  }
}

/* ========== NOTIFICATION PANEL ========== */
.notification-panel {
  position: fixed;
  top: 80px;
  right: 20px;
  width: 350px;
  background: var(--surface-white);
  border-radius: 16px;
  box-shadow: var(--shadow-elevated);
  z-index: 1000;
  padding: 20px;
  display: none;
  border: 1px solid var(--border-subtle);
}

/* ========== RESPONSIVE — Add Truck / My Trucks ========== */
@media (max-width: 1200px) {
  .trucks-stats       { grid-template-columns: repeat(2, 1fr); }
  .summary-container  { grid-template-columns: 1fr; }
}

@media (max-width: 992px) {
  .fleet-filters      { flex-direction: column; align-items: stretch; }
  .fleet-search-field { width: 100%; }
  .management-header  { flex-direction: column; }
  .summary-details    { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .trucks-stats        { grid-template-columns: 1fr; }
  .fleet-pagination    { flex-wrap: wrap; }
  .notification-panel  { width: calc(100% - 40px); right: 20px; left: 20px; }
}

@media (max-width: 576px) {
  .trucks-management  { padding: 20px; }
}

/* ========== UTILITIES ========== */
[hidden] { display: none !important; }

.fa-spinner { animation: spin 1s linear infinite; }

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

::selection {
  background-color: rgba(37, 99, 235, 0.2);
  color: var(--text-primary);
}

/* ============================================
   Page: Organization
   ============================================ */

/* ========== PAGE CONTAINER ========== */
.page-organization {
  position: relative;
  min-height: 100vh;
}

/* ========== TOAST NOTIFICATION ========== */
.organization-toast {
  position: fixed;
  top: 90px;
  right: 24px;
  padding: 12px 20px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 500;
  z-index: 1100;
  animation: slideIn 0.3s ease;
  box-shadow: var(--shadow-elevated);
}

.organization-toast.success { background: var(--success); color: white; }
.organization-toast.error   { background: var(--error);   color: white; }

@keyframes slideIn {
  from { transform: translateX(100%); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

/* ========== ORGANIZATION SUMMARY ========== */
.organization-summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-bottom: 32px;
}

.organization-summary-card {
  background: var(--surface-white);
  border-radius: 20px;
  padding: 20px;
  border: 1px solid var(--border-subtle);
  display: flex;
  align-items: center;
  gap: 16px;
  transition: all 0.3s;
}

.organization-summary-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-elevated);
}

.summary-icon {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: white;
}

.summary-team     { background: linear-gradient(135deg, #2563eb, #3b82f6); }
.summary-active   { background: linear-gradient(135deg, #10b981, #34d399); }
.summary-roles    { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
.summary-security { background: linear-gradient(135deg, #f59e0b, #fbbf24); }

.organization-summary-card h3 {
  font-size: 28px;
  font-weight: 800;
  color: var(--accent-secondary);
  margin-bottom: 4px;
}

.organization-summary-card p { font-size: 13px; color: var(--text-muted); }

/* ========== ORGANIZATION LAYOUT ========== */
.organization-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  margin-bottom: 32px;
}

/* ========== ORGANIZATION CARDS ========== */
.organization-card {
  background: var(--surface-white);
  border-radius: 20px;
  padding: 28px;
  border: 1px solid var(--border-subtle);
  transition: all 0.3s;
}

.organization-card:hover { box-shadow: var(--shadow-elevated); }

.card-heading {
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.card-heading h2 {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent-secondary);
  margin-bottom: 8px;
}

.card-heading p { font-size: 14px; color: var(--text-muted); }

/* ========== FORM STYLES ========== */
.organization-form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  margin-bottom: 24px;
}

.organization-field { display: flex; flex-direction: column; gap: 8px; }

.organization-field span {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.organization-field input,
.organization-field select {
  padding: 12px 16px;
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
  font-size: 14px;
  transition: all 0.2s;
  background: var(--surface-white);
  color: var(--text-primary);
}

.organization-field input:focus,
.organization-field select:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.organization-submit-row { margin-top: 8px; }

.organization-primary-btn {
  background: var(--gradient-primary);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.organization-primary-btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-medium);
}

.organization-primary-btn:disabled { opacity: 0.6; cursor: not-allowed; }

.organization-form-note { font-size: 12px; color: var(--text-muted); margin-top: 12px; }
.organization-field-hint { font-size: 12px; color: var(--warning); }

/* ============================================
   Page: My Trucks redesign
   ============================================ */
.mytrucks-page-title {
  margin-bottom: 32px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--border-subtle, #e2e8f0);
}

.mytrucks-page-title h1 {
  margin: 0;
  color: #0f172a;
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -0.5px;
  line-height: 1.15;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.mytrucks-page-title p {
  max-width: 640px;
  margin: 10px 0 0;
  color: var(--text-secondary, #475569);
  font-size: 15px;
  line-height: 1.7;
}

.mytrucks-table-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 18px;
}

.mytrucks-section-title {
  position: relative;
  display: inline-block;
  margin: 0;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--border-subtle, #e2e8f0);
  color: #0f172a;
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
}

.mytrucks-section-title::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 80px;
  height: 3px;
  border-radius: 999px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
}

.mytrucks-header-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}

.mytrucks-filter-pill {
  padding: 6px 14px;
  border: 1px solid var(--border-subtle, #e2e8f0);
  border-radius: 999px;
  background: transparent;
  color: var(--text-secondary, #475569);
  font: inherit;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.35;
  cursor: pointer;
  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
}

.mytrucks-filter-pill:hover {
  border-color: var(--accent-primary, #2563eb);
  color: var(--accent-primary, #2563eb);
  background: var(--surface-white, #fff);
}

.mytrucks-filter-pill.is-active {
  border-color: transparent;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
  color: #fff;
  box-shadow: 0 8px 18px -14px rgba(37, 99, 235, 0.75);
}

.mytrucks-primary-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 10px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.3;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.mytrucks-primary-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 22px -16px rgba(37, 99, 235, 0.9);
}

.mytrucks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

.mytrucks-card {
  padding: 16px;
  border: 1px solid var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
  box-shadow: var(--shadow-subtle, 0 1px 3px rgba(0, 0, 0, 0.05));
  transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

.mytrucks-card:hover {
  border-color: var(--accent-primary, #2563eb);
  box-shadow: 0 14px 26px -20px rgba(15, 23, 42, 0.35);
}

.mytrucks-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}

.mytrucks-card-top strong {
  display: block;
  color: #0f172a;
  font-size: 16px;
  font-weight: 700;
  line-height: 1.35;
}

.mytrucks-card-top p {
  margin: 0;
  color: var(--text-muted, #64748b);
  font-size: 12px;
  line-height: 1.55;
}

.mytrucks-status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
}

.mytrucks-status-pill--available {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.mytrucks-status-pill--on_job {
  background: rgba(59, 130, 246, 0.12);
  color: #3b82f6;
}

.mytrucks-status-pill--maintenance {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
}

.mytrucks-status-pill--inactive {
  background: rgba(100, 116, 139, 0.15);
  color: #475569;
}

.mytrucks-stats-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 8px;
  margin: 14px 0;
  padding: 10px 0;
  border-top: 1px solid var(--border-subtle, #e2e8f0);
  border-bottom: 1px solid var(--border-subtle, #e2e8f0);
}

.mytrucks-stats-grid span,
.mytrucks-stats-grid b {
  display: block;
}

.mytrucks-stats-grid span {
  color: var(--text-muted, #64748b);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.5px;
  line-height: 1.3;
  text-transform: uppercase;
}

.mytrucks-stats-grid b {
  margin-top: 4px;
  color: #0f172a;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
}

.mytrucks-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 12px;
  color: var(--text-muted, #64748b);
  font-size: 12px;
}

.mytrucks-card-meta > span {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mytrucks-card-meta i {
  margin-right: 4px;
  color: var(--accent-primary, #2563eb);
}

.mytrucks-card-meta > div {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  gap: 6px;
}

.mytrucks-ghost-btn,
.mytrucks-action-small {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  line-height: 1.25;
  white-space: nowrap;
  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.mytrucks-ghost-btn {
  padding: 8px 14px;
  border: 1px solid var(--border-subtle, #e2e8f0);
  border-radius: 8px;
  background: var(--hover-bg, #f1f5f9);
  color: var(--text-secondary, #475569);
  font-size: 13px;
  font-weight: 600;
}

.mytrucks-ghost-btn:hover {
  border-color: var(--accent-primary, #2563eb);
  background: var(--surface-white, #fff);
  color: var(--accent-primary, #2563eb);
}

.mytrucks-action-small {
  padding: 6px 14px;
  border-radius: 8px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
  color: #fff;
  font-size: 12px;
  font-weight: 600;
}

.mytrucks-action-small:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px -12px rgba(37, 99, 235, 0.85);
}

.mytrucks-activate-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  box-shadow: 0 10px 20px -14px rgba(37, 99, 235, 0.95);
}

.mytrucks-activate-btn:hover {
  box-shadow: 0 12px 24px -14px rgba(29, 78, 216, 0.95);
}

.mytrucks-loading,
.mytrucks-empty-state {
  color: #94a3b8;
  text-align: center;
}

.mytrucks-loading {
  padding: 3rem;
}

.mytrucks-loading i {
  color: var(--accent-primary, #2563eb);
  font-size: 1.5rem;
}

.mytrucks-loading p {
  margin-top: 10px;
  color: var(--text-muted, #64748b);
}

.mytrucks-empty-state {
  padding: 2rem;
  border: 1px dashed var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
}

.mytrucks-empty-state i {
  display: block;
  margin-bottom: 10px;
  font-size: 2rem;
}

.mytrucks-empty-state p {
  margin-bottom: 10px;
}

.mytrucks-empty-state a {
  color: var(--accent-primary, #2563eb);
  font-weight: 600;
  text-decoration: none;
}

.mytrucks-empty-state a:hover {
  text-decoration: underline;
}

/* ============================================
   Page: Active Jobs route timeline
   ============================================ */
.job-page-title {
  margin-bottom: 32px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--border-subtle, #e2e8f0);
}

.job-page-title h1 {
  margin: 0;
  color: #0f172a;
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -0.5px;
  line-height: 1.15;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.job-page-title p {
  max-width: 640px;
  margin: 10px 0 0;
  color: var(--text-secondary, #475569);
  font-size: 15px;
  line-height: 1.7;
}

.job-section {
  margin-bottom: 36px;
}

.job-section-title {
  position: relative;
  display: inline-block;
  margin: 0 0 20px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--border-subtle, #e2e8f0);
  color: #0f172a;
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
}

.job-section-title::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 80px;
  height: 3px;
  border-radius: 999px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
}

.job-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.job-card {
  display: grid;
  grid-template-columns: 2fr 2fr auto;
  align-items: center;
  gap: 18px;
  padding: 18px;
  border: 1px solid var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
  box-shadow: var(--shadow-subtle, 0 1px 3px rgba(0, 0, 0, 0.05));
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.job-card:hover {
  border-color: var(--accent-primary, #2563eb);
  box-shadow: 0 14px 26px -22px rgba(15, 23, 42, 0.4);
}

.job-route {
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  gap: 10px;
  align-items: start;
}

.job-pin-column {
  display: grid;
  grid-template-rows: 18px 20px 18px;
  justify-items: center;
  align-items: center;
  padding-top: 25px;
}

.job-origin-pin {
  color: #10b981;
  font-size: 9px;
}

.job-route-line {
  width: 2px;
  height: 20px;
  background: var(--border-light, #cbd5e1);
}

.job-destination-pin {
  color: #ef4444;
  font-size: 14px;
}

.job-route-copy {
  min-width: 0;
}

.job-source-badge,
.job-id {
  display: inline-flex;
  align-items: center;
  width: fit-content;
}

.job-source-badge {
  margin: 0 8px 7px 0;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 700;
  line-height: 1.4;
}

.job-source-badge--one-time {
  background: #eff6ff;
  color: #2563eb;
}

.job-source-badge--agreement {
  background: #fef3c7;
  color: #d97706;
}

.job-id {
  color: var(--text-muted, #64748b);
  font-size: 11px;
  font-weight: 700;
}

.job-route-copy b,
.job-meta-grid b {
  display: block;
  color: #0f172a;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
}

.job-route-copy span:not(.job-source-badge):not(.job-id) {
  display: block;
  margin-top: 2px;
  color: var(--text-muted, #64748b);
  font-size: 11px;
  line-height: 1.45;
}

.job-route-spacer {
  height: 18px;
}

.job-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px 16px;
}

.job-meta-grid span {
  display: block;
  margin-bottom: 4px;
  color: var(--text-muted, #64748b);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.5px;
  line-height: 1.3;
  text-transform: uppercase;
}

.job-meta-grid b {
  font-size: 13px;
}

.job-meta-grid .job-earnings {
  color: #10b981;
}

.job-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.job-status-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
}

.job-status-pill--transit {
  background: rgba(59, 130, 246, 0.12);
  color: #3b82f6;
}

.job-status-pill--pickup {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
}

.job-status-pill--delivered {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.job-status-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #3b82f6;
  animation: job-pulse 1.4s ease-in-out infinite;
}

.job-action-small {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 14px;
  border-radius: 8px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
  color: #fff;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.25;
  text-decoration: none;
  white-space: nowrap;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.job-action-small:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px -12px rgba(37, 99, 235, 0.85);
}

.job-loading,
.job-empty-state {
  color: var(--text-muted, #64748b);
  text-align: center;
}

.job-loading {
  padding: 3rem;
}

.job-loading i {
  color: var(--accent-primary, #2563eb);
  font-size: 1.5rem;
}

.job-loading p {
  margin-top: 10px;
}

.job-empty-state {
  padding: 2rem;
  border: 1px dashed var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
}

.job-empty-state i {
  display: block;
  margin-bottom: 10px;
  color: #94a3b8;
  font-size: 2rem;
}

.job-empty-state p {
  margin: 0;
}

.job-empty-state a {
  color: var(--accent-primary, #2563eb);
  font-weight: 600;
  text-decoration: none;
}

.job-empty-state a:hover {
  text-decoration: underline;
}

/* ============================================
   Page: Earnings payouts
   ============================================ */
.payout-page-title {
  margin-bottom: 32px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--border-subtle, #e2e8f0);
}

.payout-page-title h1 {
  margin: 0;
  color: #0f172a;
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -0.5px;
  line-height: 1.15;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.payout-page-title p {
  max-width: 640px;
  margin: 10px 0 0;
  color: var(--text-secondary, #475569);
  font-size: 15px;
  line-height: 1.7;
}

.payout-kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
  margin-bottom: 36px;
}

.payout-kpi-card {
  padding: 20px;
  border: 1px solid var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
  box-shadow: var(--shadow-subtle, 0 1px 3px rgba(0, 0, 0, 0.05));
  transition: transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
}

.payout-kpi-card:hover {
  transform: translateY(-6px);
  border-color: var(--accent-primary, #2563eb);
  box-shadow: 0 14px 28px -18px rgba(15, 23, 42, 0.45);
}

.payout-kpi-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
}

.payout-card-value {
  color: #0f172a;
  font-size: 26px;
  font-weight: 800;
  white-space: nowrap;
}

.payout-card-title {
  margin-top: 6px;
  color: var(--text-muted, #64748b);
  font-size: 13px;
  font-weight: 500;
}

.payout-card-icon {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  color: #fff;
  font-size: 20px;
  box-shadow: 0 6px 14px -4px rgba(0, 0, 0, 0.25);
}

.payout-icon--green { background: linear-gradient(135deg, #10b981, #34d399); }
.payout-icon--blue { background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6)); }
.payout-icon--amber { background: linear-gradient(135deg, #f59e0b, #fb923c); }
.payout-icon--violet { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }

.payout-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px solid var(--border-subtle, #e2e8f0);
  color: var(--text-muted, #64748b);
  font-size: 12px;
}

.payout-action-small {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 14px;
  border-radius: 8px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
  color: #fff;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.25;
  text-decoration: none;
  white-space: nowrap;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.payout-action-small:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px -12px rgba(37, 99, 235, 0.85);
}

.payout-section {
  margin-bottom: 36px;
}

.payout-section-title {
  position: relative;
  display: inline-block;
  margin: 0 0 20px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--border-subtle, #e2e8f0);
  color: #0f172a;
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
}

.payout-section-title::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 80px;
  height: 3px;
  border-radius: 999px;
  background: var(--gradient-primary, linear-gradient(135deg, #2563eb, #3b82f6));
}

.payout-table {
  overflow: hidden;
  border: 1px solid var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
}

.payout-table-row {
  display: grid;
  grid-template-columns: 1fr 1.2fr 2fr 1fr 1fr;
  align-items: center;
  gap: 16px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border-subtle, #e2e8f0);
  color: var(--text-primary, #1e293b);
  font-size: 13px;
}

.payout-table-row.has-extras {
  grid-template-columns: 1fr 1.2fr 2fr 1fr 1fr 1fr;
}

.payout-table-row:last-child {
  border-bottom: none;
}

.payout-table-row--head {
  background: var(--hover-bg, #f1f5f9);
  color: var(--text-muted, #64748b);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.payout-table-row > span:last-child {
  text-align: right;
}

.payout-reference {
  color: var(--text-secondary, #475569);
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 12px;
}

.payout-status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
}

.payout-status-pill--paid {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.payout-status-pill--pending {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
}

.payout-amount {
  color: #0f172a;
  font-weight: 700;
}

.payout-loading,
.payout-empty-state {
  color: var(--text-muted, #64748b);
  text-align: center;
}

.payout-loading {
  padding: 3rem;
}

.payout-loading i {
  color: var(--accent-primary, #2563eb);
  font-size: 1.5rem;
}

.payout-loading p {
  margin-top: 10px;
}

.payout-empty-state {
  padding: 2rem;
  border: 1px dashed var(--border-subtle, #e2e8f0);
  border-radius: 14px;
  background: var(--surface-white, #fff);
}

.payout-empty-state i {
  display: block;
  margin-bottom: 10px;
  color: #94a3b8;
  font-size: 2rem;
}

.payout-empty-state p {
  margin: 0;
}

@media (max-width: 880px) {
  .payout-table {
    overflow-x: auto;
  }

  .payout-table-row {
    min-width: 760px;
  }

  .payout-table-row.has-extras {
    min-width: 900px;
  }
}

/* ============================================
   Page: Earnings dashboard redesign
   ============================================ */
.earnings-dashboard {
  color: #111827;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.earnings-dashboard .payout-page-title h1 {
  color: #111827;
  background: none;
  -webkit-text-fill-color: #111827;
}

.earnings-dashboard .payout-page-title p {
  color: #6B7280;
}

.earnings-card {
  border: 1px solid #E5E7EB;
  border-radius: 16px;
  background: #FFFFFF;
  box-shadow: 0px 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.earnings-alert {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
  padding: 12px 16px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
}

.earnings-alert--error {
  border: 1px solid rgba(239, 68, 68, 0.25);
  background: rgba(239, 68, 68, 0.08);
  color: #991B1B;
}

.earnings-alert--success {
  border: 1px solid rgba(16, 185, 129, 0.25);
  background: rgba(16, 185, 129, 0.1);
  color: #047857;
}

.earnings-stats-grid,
.earnings-action-grid,
.earnings-tier-grid {
  display: grid;
  gap: 24px;
}

.earnings-stats-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-bottom: 24px;
}

.earnings-stat-card {
  display: flex;
  align-items: center;
  gap: 16px;
  min-width: 0;
  padding: 24px;
}

.earnings-stat-card strong,
.earnings-wallet-metric strong,
.earnings-current-tier strong {
  display: block;
  color: #111827;
  font-size: 24px;
  font-weight: 800;
  line-height: 1.2;
  overflow-wrap: anywhere;
}

.earnings-stat-card span,
.earnings-wallet-metric span,
.earnings-current-tier span {
  display: block;
  margin-top: 6px;
  color: #6B7280;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.35;
}

.earnings-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 46px;
  height: 46px;
  border-radius: 12px;
  font-size: 18px;
}

.earnings-icon--indigo {
  background: rgba(79, 70, 229, 0.1);
  color: #4F46E5;
}

.earnings-icon--green {
  background: rgba(16, 185, 129, 0.12);
  color: #10B981;
}

.earnings-icon--yellow {
  background: rgba(245, 158, 11, 0.14);
  color: #F59E0B;
}

.earnings-icon--gray {
  background: #F3F4F6;
  color: #6B7280;
}

.earnings-wallet-card,
.earnings-recent-card {
  margin-bottom: 24px;
  padding: 24px;
}

.earnings-section-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 22px;
}

.earnings-section-heading h2 {
  margin: 0;
  color: #111827;
  font-size: 20px;
  font-weight: 800;
  line-height: 1.25;
}

.earnings-section-heading p {
  margin: 6px 0 0;
  color: #6B7280;
  font-size: 14px;
  line-height: 1.5;
}

.earnings-wallet-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.earnings-wallet-metric {
  min-width: 0;
  padding: 18px;
  border: 1px solid #E5E7EB;
  border-radius: 14px;
  background: #FFFFFF;
}

.earnings-wallet-metric--locked strong {
  color: #6B7280;
}

.earnings-wallet-metric--accent strong {
  color: #4F46E5;
}

.earnings-wallet-metric small {
  display: inline-flex;
  width: fit-content;
  margin-top: 10px;
  padding: 5px 10px;
  border-radius: 999px;
  background: #F9FAFB;
  color: #F59E0B;
  font-size: 12px;
  font-weight: 700;
}

.earnings-action-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-bottom: 24px;
}

.earnings-dashed-card {
  min-width: 0;
  padding: 24px;
  border: 2px dashed #D1D5DB;
  border-radius: 16px;
  background: #F9FAFB;
  text-align: center;
}

.earnings-dashed-card > i {
  color: #9CA3AF;
  font-size: 28px;
}

.earnings-dashed-card h3 {
  margin: 12px 0 6px;
  color: #111827;
  font-size: 17px;
  font-weight: 800;
}

.earnings-dashed-card p,
.earnings-card-summary span,
.earnings-limit-note {
  color: #6B7280;
  font-size: 14px;
  line-height: 1.5;
}

.earnings-card-summary {
  display: grid;
  gap: 4px;
  margin: 12px 0;
}

.earnings-card-summary strong {
  color: #111827;
  font-size: 16px;
}

.earnings-primary-btn,
.earnings-secondary-btn,
.earnings-outline-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 38px;
  padding: 9px 14px;
  border-radius: 8px;
  font: inherit;
  font-size: 13px;
  font-weight: 800;
  line-height: 1.2;
  cursor: pointer;
  transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.earnings-primary-btn {
  border: 1px solid #4F46E5;
  background: #4F46E5;
  color: #FFFFFF;
  box-shadow: 0 10px 18px -14px rgba(79, 70, 229, 0.85);
}

.earnings-primary-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 12px 22px -14px rgba(79, 70, 229, 0.95);
}

.earnings-secondary-btn {
  margin-top: 10px;
  border: 1px solid #E5E7EB;
  background: #FFFFFF;
  color: #4F46E5;
}

.earnings-outline-btn {
  border: 1px solid #4F46E5;
  background: #FFFFFF;
  color: #4F46E5;
}

.earnings-primary-btn:disabled,
.earnings-secondary-btn:disabled,
.earnings-outline-btn:disabled,
.earnings-withdraw-row input:disabled {
  cursor: not-allowed;
  opacity: 1;
}

.earnings-primary-btn:disabled {
  border-color: #D1D5DB;
  background: #E5E7EB;
  color: #9CA3AF;
  box-shadow: none;
}

.earnings-card-form {
  display: grid;
  gap: 12px;
  margin-top: 18px;
  text-align: left;
}

.earnings-card-form label {
  display: grid;
  gap: 6px;
}

.earnings-card-form label span {
  color: #6B7280;
  font-size: 12px;
  font-weight: 800;
}

.earnings-card-form input,
.earnings-withdraw-row input {
  width: 100%;
  min-width: 0;
  border: 1px solid #D1D5DB;
  border-radius: 8px;
  background: #FFFFFF;
  color: #111827;
  font: inherit;
}

.earnings-card-form input {
  padding: 10px 12px;
}

.earnings-form-row,
.earnings-withdraw-row {
  display: grid;
  gap: 12px;
}

.earnings-form-row {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.earnings-withdraw-row {
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  margin-top: 16px;
}

.earnings-withdraw-row input {
  padding: 10px 12px;
}

.earnings-limit-note {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 14px;
}

.earnings-limit-note strong {
  color: #111827;
}

.earnings-limit-note span {
  width: 1px;
  background: #D1D5DB;
}

.earnings-limits-section {
  margin-bottom: 24px;
}

.earnings-current-tier {
  display: grid;
  grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-bottom: 24px;
  padding: 22px;
  border: 1px solid rgba(79, 70, 229, 0.28);
  border-radius: 16px;
  background: rgba(79, 70, 229, 0.06);
  box-shadow: 0px 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.earnings-current-tier small {
  display: block;
  margin-top: 6px;
  color: #6B7280;
  font-size: 12px;
  font-weight: 700;
}

.earnings-tier-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.earnings-tier-card {
  display: flex;
  min-width: 0;
  min-height: 100%;
  padding: 22px;
  flex-direction: column;
}

.earnings-tier-card.is-active {
  border-color: #4F46E5;
  background: rgba(79, 70, 229, 0.04);
}

.earnings-tier-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 18px;
}

.earnings-tier-title h3 {
  margin: 0;
  color: #111827;
  font-size: 18px;
  font-weight: 800;
}

.earnings-tier-title span {
  padding: 4px 9px;
  border-radius: 999px;
  background: rgba(16, 185, 129, 0.12);
  color: #10B981;
  font-size: 11px;
  font-weight: 800;
}

.earnings-tier-card ul {
  display: grid;
  gap: 12px;
  margin: 0 0 20px;
  padding: 0;
  list-style: none;
}

.earnings-tier-card li {
  display: grid;
  grid-template-columns: 20px minmax(0, 1fr);
  gap: 8px 10px;
  align-items: center;
}

.earnings-tier-card li i {
  grid-row: span 2;
  color: #4F46E5;
  font-size: 13px;
}

.earnings-tier-card li span {
  color: #6B7280;
  font-size: 12px;
  font-weight: 700;
}

.earnings-tier-card li strong {
  color: #111827;
  font-size: 16px;
  font-weight: 800;
}

.earnings-tier-actions {
  display: grid;
  gap: 10px;
  margin-top: auto;
}

.earnings-tier-actions button {
  width: 100%;
  justify-content: space-between;
}

.earnings-tier-actions button span {
  font-size: 11px;
  font-weight: 700;
}

.earnings-confirm-card {
  margin-top: 24px;
  padding: 22px;
  border-color: rgba(79, 70, 229, 0.35);
}

.earnings-confirm-card h3 {
  margin: 0;
  color: #111827;
  font-size: 18px;
  font-weight: 800;
}

.earnings-confirm-card p {
  margin: 6px 0 16px;
  color: #6B7280;
  font-size: 14px;
}

.earnings-confirm-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 18px;
}

.earnings-confirm-grid span {
  display: grid;
  gap: 4px;
  padding: 12px;
  border-radius: 12px;
  background: #F9FAFB;
  color: #6B7280;
  font-size: 12px;
  font-weight: 700;
}

.earnings-confirm-grid strong {
  color: #111827;
  font-size: 14px;
}

.earnings-confirm-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.earnings-table {
  overflow: hidden;
  border: 1px solid #E5E7EB;
  border-radius: 14px;
}

.earnings-table-row {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: 16px;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #E5E7EB;
  color: #111827;
  font-size: 14px;
}

.earnings-table-row:last-child {
  border-bottom: 0;
}

.earnings-table-row--head {
  background: #F9FAFB;
  color: #6B7280;
  font-size: 12px;
  font-weight: 800;
}

.earnings-table-row strong {
  color: #10B981;
  text-align: right;
}

.earnings-table-empty {
  display: grid;
  place-items: center;
  min-height: 180px;
  padding: 32px;
  border: 1px dashed #D1D5DB;
  border-radius: 14px;
  background: #F9FAFB;
  color: #6B7280;
  text-align: center;
}

.earnings-table-empty i {
  margin-bottom: 12px;
  color: #9CA3AF;
  font-size: 28px;
}

.earnings-table-empty p {
  margin: 0;
  max-width: 420px;
  color: #6B7280;
  font-size: 14px;
}

@media (max-width: 1180px) {
  .earnings-stats-grid,
  .earnings-tier-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .earnings-current-tier {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 820px) {
  .earnings-action-grid,
  .earnings-wallet-grid,
  .earnings-confirm-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .earnings-stats-grid,
  .earnings-tier-grid,
  .earnings-current-tier,
  .earnings-form-row,
  .earnings-withdraw-row {
    grid-template-columns: 1fr;
  }

  .earnings-stat-card,
  .earnings-wallet-card,
  .earnings-recent-card,
  .earnings-dashed-card,
  .earnings-tier-card {
    padding: 18px;
  }

  .earnings-limit-note,
  .earnings-confirm-actions {
    justify-content: flex-start;
  }

  .earnings-table {
    overflow-x: auto;
  }

  .earnings-table-row {
    min-width: 620px;
  }
}

@keyframes job-pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.45;
    transform: scale(1.35);
  }
}

@media (max-width: 980px) {
  .job-card {
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .job-actions {
    align-items: flex-start;
    flex-direction: row;
    justify-content: space-between;
  }
}

@media (max-width: 560px) {
  .job-meta-grid {
    grid-template-columns: 1fr;
  }
}

/* ========== SECURITY STEPS ========== */
.security-steps { margin-bottom: 24px; }

.security-step {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.security-step:last-child { border-bottom: none; }

.step-number {
  width: 32px;
  height: 32px;
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  flex-shrink: 0;
}

.security-step strong { display: block; font-size: 15px; color: var(--accent-secondary); margin-bottom: 4px; }
.security-step p      { font-size: 13px; color: var(--text-muted); }

.organization-role-access-card { margin-bottom: 32px; }

.organization-role-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.role-chip-card {
  background: linear-gradient(180deg, rgba(241, 245, 249, 0.92), rgba(248, 250, 252, 0.98));
  border-radius: 16px;
  padding: 18px;
  border: 1px solid var(--border-subtle);
  transition: all 0.3s;
  min-height: 148px;
  display: flex;
  flex-direction: column;
}

.role-chip-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-medium);
}

.role-chip-card strong {
  display: block;
  font-size: 15px;
  color: var(--accent-secondary);
  margin-bottom: 8px;
}

.role-chip-card p {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 14px;
  flex: 1;
}

.role-chip-card span {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  font-size: 11px;
  padding: 5px 10px;
  background: var(--surface-white);
  border: 1px solid rgba(37, 99, 235, 0.12);
  border-radius: 999px;
  color: var(--accent-primary);
  font-weight: 600;
  word-break: break-all;
}

/* ========== MEMBERS SECTION ========== */
.organization-members-card { margin-bottom: 32px; }

.organization-members-heading {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}

.organization-members-meta { display: flex; gap: 12px; }

.organization-members-meta span {
  padding: 4px 12px;
  background: var(--hover-bg);
  border-radius: 20px;
  font-size: 12px;
  color: var(--text-muted);
}

.organization-member-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  margin-top: 20px;
}

.organization-member-card {
  background: var(--hover-bg);
  border-radius: 16px;
  padding: 20px;
  border: 1px solid var(--border-subtle);
  transition: all 0.3s;
}

.organization-member-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-medium);
}

.organization-member-card.is-inactive { opacity: 0.7; }

.member-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border-subtle);
}

.member-card-header h3 { font-size: 16px; font-weight: 700; color: var(--accent-secondary); margin-bottom: 4px; }
.member-card-header p  { font-size: 12px; color: var(--text-muted); }

.member-status { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }

.member-status.active   { background: rgba(16, 185, 129, 0.1); color: var(--success); }
.member-status.inactive { background: rgba(239, 68, 68, 0.1);  color: var(--error); }

.member-card-body { margin-bottom: 16px; }

.member-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.member-detail-row:last-child { border-bottom: none; }
.member-detail-row span       { font-size: 12px; color: var(--text-muted); }
.member-detail-row strong     { font-size: 13px; color: var(--text-primary); }

.member-card-actions { display: flex; gap: 10px; flex-wrap: wrap; }

.organization-secondary-btn {
  background: var(--surface-white);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  padding: 8px 14px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.organization-secondary-btn:hover         { background: var(--gradient-primary); border-color: transparent; color: white; }
.organization-secondary-btn.danger:hover  { background: var(--error); }
.organization-secondary-btn.success:hover { background: var(--success); }
.organization-secondary-btn:disabled      { opacity: 0.6; cursor: not-allowed; }

.organization-owner-note {
  margin-top: 24px;
  padding: 16px;
  background: rgba(37, 99, 235, 0.05);
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 13px;
  color: var(--text-secondary);
  border-left: 3px solid var(--accent-primary);
}

/* ========== EMPTY STATE ========== */
.organization-empty-state { text-align: center; padding: 60px 40px; color: var(--text-muted); }
.organization-empty-state i { font-size: 48px; margin-bottom: 16px; display: block; color: var(--border-light); }
.organization-empty-state p { font-size: 14px; }

/* ========== CREDENTIALS MODAL ========== */
.organization-credentials-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.organization-credentials-modal {
  background: var(--surface-white);
  border-radius: 24px;
  max-width: 480px;
  width: 90%;
  padding: 28px;
  position: relative;
  box-shadow: var(--shadow-elevated);
  border: 1px solid var(--border-subtle);
}

.credentials-close {
  position: absolute;
  top: 20px;
  right: 20px;
  background: none;
  border: none;
  font-size: 20px;
  cursor: pointer;
  color: var(--text-muted);
  transition: color 0.2s;
}

.credentials-close:hover { color: var(--error); }

.organization-credentials-modal h2 { font-size: 22px; font-weight: 700; color: var(--accent-secondary); margin-bottom: 8px; }
.organization-credentials-modal p  { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; }

.credentials-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: var(--hover-bg);
  border-radius: 12px;
  margin-bottom: 12px;
}

.credentials-box span   { font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 6px; }
.credentials-box strong { font-size: 15px; color: var(--text-primary); }

.credentials-box button {
  background: var(--surface-white);
  border: 1px solid var(--border-subtle);
  padding: 8px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  color: var(--accent-primary);
}

.credentials-box button:hover { background: var(--gradient-primary); color: white; }

.credentials-box.muted { opacity: 0.8; }

.credentials-actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.credentials-actions .organization-primary-btn,
.credentials-actions .organization-secondary-btn { flex: 1; justify-content: center; }

/* ========== RESPONSIVE — Organization ========== */
@media (max-width: 1200px) {
  .organization-summary     { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .organization-member-grid { grid-template-columns: 1fr; }
}

@media (max-width: 992px) {
  .organization-layout        { grid-template-columns: 1fr; gap: 24px; }
  .organization-form-grid     { grid-template-columns: 1fr; gap: 16px; }
  .organization-role-grid     { grid-template-columns: 1fr; }
  .member-card-actions        { flex-direction: column; }
  .organization-secondary-btn { width: 100%; justify-content: center; }
}

@media (max-width: 768px) {
  .organization-summary         { grid-template-columns: 1fr; }
  .organization-summary-card h3 { font-size: 24px; }
  .organization-members-heading { flex-direction: column; align-items: flex-start; }
  .credentials-actions          { flex-direction: column; }
  .organization-card            { padding: 20px; }
}

@media (max-width: 576px) {
  .summary-icon                   { width: 48px; height: 48px; font-size: 20px; }
  .member-detail-row              { flex-direction: column; align-items: flex-start; gap: 4px; }
  .organization-credentials-modal { padding: 20px; }
  .credentials-box                { flex-direction: column; gap: 12px; text-align: center; }
}
