  gap: 6px;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.1);
  color: var(--accent-primary);
  font-size: 12px;
  font-weight: 700;
}

.transporter-page .status-badge.success,
.transporter-page .member-status.active,
.transporter-page .green {
  background: rgba(16, 185, 129, 0.12);
  color: var(--success);
}

.transporter-page .status-badge.error,
.transporter-page .member-status.inactive,
.transporter-page .red {
  background: rgba(239, 68, 68, 0.12);
  color: var(--error);
}

.transporter-page .yellow {
